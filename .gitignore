# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
env/
venv/
ENV/
.venv/

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data - don't commit user input/output files
Data/Outputs/*
!Data/Outputs/.gitkeep
Data/Inputs/*.fasta
Data/Inputs/*.fa
Data/Inputs/*.csv
Data/Inputs/*.tsv
Data/Inputs/*.txt

# User-generated output (analysis plots, exported structures).
# Keep the app icon and any images committed under docs/ or Examples/.
*.svg
*.png
!icon.png
!docs/**/*.png
!docs/**/*.svg
!Examples/**/*.png

# Built applications (too large for git)
*.zip
*.dmg
*.exe
*.app/

# OS junk
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Temporary
*.tmp
*.log
*.cache

# Runtime settings / state files (generated on first run)
csv_output_settings.json
.recent_files.json

# Test outputs
test_output/
temp/
